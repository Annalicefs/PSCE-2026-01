  21          /* Function to provide delay Approx 1ms with 11.0592 Mhz crystal */
  22          void delay(unsigned int count)
  23          {
  24   1          int i, j;
  25   1          for(i=0; i<count; i++)
  26   1              for(j=0; j<112; j++);
  27   1      }
  28          
  29          /* LCD16x2 command function */
  30          void LCD_Command(char cmnd) 
  31          {
  32   1          LCD_Port = (LCD_Port & 0x0F) | (cmnd & 0xF0); /* Send upper nibble */
  33   1          rs = 0;                 /* Command reg. */
  34   1          rw = 0;                 /* Write operation */
  35   1          en = 1;                 /* Enable pulse */
  36   1          delay(1);
  37   1          en = 0;
  38   1          delay(2);
  39   1          LCD_Port = (LCD_Port & 0x0F) | (cmnd << 4);   /* Send lower nibble */
  40   1          en = 1;                 /* Enable pulse */
  41   1          delay(1);
  42   1          en = 0;
  43   1          delay(5);
  44   1      
  45   1      }
  46          
  47          /* LCD data write function */
  48          void LCD_Char(char char_data) 
  49          {
  50   1          LCD_Port = (LCD_Port & 0x0F) | (char_data & 0xF0); /* Send upper nibble */
  51   1          rs = 1;                 /* Data reg. */
  52   1          rw = 0;                 /* Write operation */
  53   1          en = 1;                 /* Enable pulse */
  54   1          delay(1);
C51 COMPILER V9.60.7.0   TREX_LCD                                                          05/26/2026 21:57:46 PAGE 2   

  55   1          en = 0;
  56   1          delay(2);
  57   1          LCD_Port = (LCD_Port & 0x0F) | (char_data << 4);   /* Send lower nibble */
  58   1          en = 1;                 /* Enable pulse */
  59   1          delay(1);
  60   1          en = 0;
  61   1          delay(5);
  62   1      
  63   1      }
  64          
  65          /* Send string to LCD function */
  66          void LCD_String(char *str) 
  67          {
  68   1          int i;
  69   1          for(i=0; str[i]!=0; i++) /* Send each char of string till the NULL */
  70   1          {
  71   2              LCD_Char(str[i]);    /* Call LCD data write */
  72   2          }
  73   1      }
  74          
  75          /* Send string to LCD function based on X,Y position */
  76          void LCD_String_xy(char row, char pos, char *str) 
  77          {
  78   1          if (row == 0)
  79   1              LCD_Command((pos & 0x0F) | 0x80);
  80   1          else if (row == 1)
  81   1              LCD_Command((pos & 0x0F) | 0xC0);
  82   1          
  83   1          LCD_String(str);         /* Call LCD string function */
  84   1      }
  85          
  86          /* LCD Initialize function */
  87          void LCD_Init(void) 
  88          {
  89   1          delay(20);               /* LCD Power ON Initialization time >15ms */
  90   1          LCD_Command(0x02);       /* 4bit mode */
  91   1          LCD_Command(0x28);       /* Initialization of 16X2 LCD in 4bit mode */
  92   1          LCD_Command(0x0C);       /* Display ON Cursor OFF */
  93   1          LCD_Command(0x06);       /* Auto Increment cursor */
  94   1          LCD_Command(0x01);       /* Clear display */
  95   1          LCD_Command(0x80);       /* Cursor at home position */
  96   1      }
