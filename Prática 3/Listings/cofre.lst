  19          /* Function to provide delay Approx 1ms with 11.0592 Mhz crystal */
  20          void delay(unsigned int count)
  21          {
  22   1          int i, j;
  23   1          for(i=0; i<count; i++)
  24   1              for(j=0; j<112; j++);
  25   1      }
