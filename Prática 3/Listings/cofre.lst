  27          /* LCD16x2 command function */
  28          void LCD_Command(char cmnd) 
  29          {
  30   1          LCD_Port = (LCD_Port & 0x0F) | (cmnd & 0xF0); /* Send upper nibble */
  31   1          rs = 0;                 /* Command reg. */
  32   1          rw = 0;                 /* Write operation */
  33   1          en = 1;                 /* Enable pulse */
  34   1          delay(1);
  35   1          en = 0;
  36   1          delay(2);
  37   1          LCD_Port = (LCD_Port & 0x0F) | (cmnd << 4);   /* Send lower nibble */
  38   1          en = 1;                 /* Enable pulse */
  39   1          delay(1);
  40   1          en = 0;
  41   1          delay(5);
  42   1      }
  43          
  44          /* LCD data write function */
  45          void LCD_Char(char char_data) 
  46          {
  47   1          LCD_Port = (LCD_Port & 0x0F) | (char_data & 0xF0); /* Send upper nibble */
  48   1          rs = 1;                 /* Data reg. */
  49   1          rw = 0;                 /* Write operation */
  50   1          en = 1;                 /* Enable pulse */
  51   1          delay(1);
  52   1          en = 0;
  53   1          delay(2);
  54   1          LCD_Port = (LCD_Port & 0x0F) | (char_data << 4);   /* Send lower nibble */
